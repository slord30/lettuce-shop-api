              }
            }
          },
          "404": { "description": "Store not found" }
        }
      },
      "put": {
        "summary": "Update a store",
        "tags": ["stores"],
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Store updated" },
